# ============================================================
# .gitignore — Barcode Portal Automation System
# ============================================================

# ── Environment (NEVER commit real secrets) ────────────────
.env
.env.local
.env.production
.env.*.local

# ── Node / React ───────────────────────────────────────────
node_modules/
/node_modules/
frontend/node_modules/
frontend/build/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
bot/venv/
bot/.venv/
bot/env/
bot/ENV/
*.egg-info/
dist/
build/

# ── Bot runtime output ─────────────────────────────────────
bot/logs/
bot/screenshots/
bot/downloads/
bot/temp/

# ── PHP session files ──────────────────────────────────────
portals/*/sessions/
dummy-portal/sessions/

# ── PHP generated files ────────────────────────────────────
portals/*/generated/
dummy-portal/generated/
backend/downloads/

# ── Uploads (user data, not source code) ──────────────────
backend/uploads/

# ── SSL certificates (contain private keys) ───────────────
nginx/ssl/*.pem
nginx/ssl/*.crt
nginx/ssl/*.key
nginx/ssl/*.p12

# ── IDE & OS ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
Desktop.ini

# ── Docker override (local customizations) ─────────────────
docker-compose.override.yml

# ── Logs ───────────────────────────────────────────────────
*.log
logs/
