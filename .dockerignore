# ============================================================
# .dockerignore — root build context exclusions
#
# This file applies when build context is "." (project root).
# Currently that means: backend service only.
#
# frontend context = ./frontend → reads frontend/.dockerignore
# bot context      = ./bot     → reads bot/.dockerignore
# ============================================================

# ── Git ────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── Node / React ───────────────────────────────────────────
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-error.log*
yarn-debug.log*

# ── React build/dev artifacts ──────────────────────────────
frontend/build/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# ── Python (bot not in backend context, but guard anyway) ──
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
bot/venv/
bot/.venv/
bot/env/
bot/ENV/
bot/logs/
bot/screenshots/
bot/downloads/
bot/temp/
bot/.pytest_cache/
bot/.mypy_cache/

# ── Environment / secrets ──────────────────────────────────
.env
.env.*
!.env.example

# ── IDE / OS ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
Desktop.ini

# ── Docker override ────────────────────────────────────────
docker-compose.override.yml

# ── Runtime data / user uploads ────────────────────────────
backend/uploads/
backend/downloads/
portals/*/sessions/
dummy-portal/sessions/
portals/*/generated/
dummy-portal/generated/

# ── SSL private keys ───────────────────────────────────────
nginx/ssl/*.pem
nginx/ssl/*.crt
nginx/ssl/*.key
nginx/ssl/*.p12

# ── Logs ───────────────────────────────────────────────────
*.log
logs/

# ── Docs (not needed in images) ────────────────────────────
*.md
docs/

# ── Test / sample data ─────────────────────────────────────
samples/
*.test.js
