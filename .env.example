# ============================================================
# Barcode Portal — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── MySQL ──────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme_root_password
MYSQL_DATABASE=barcode_portal
MYSQL_USER=barcode_user
MYSQL_PASSWORD=changeme_db_password

# ── Application ────────────────────────────────────────────
# Your server's public URL (no trailing slash)
# Used for CORS headers and portal URL remapping.
# Examples:
#   http://localhost          (local dev / test)
#   https://yourdomain.com    (production)
APP_URL=http://localhost

# ── Python Bot ─────────────────────────────────────────────
# How often the bot polls for new jobs (seconds)
BOT_POLL_INTERVAL=5
