# ============================================================
# Barcode Portal Automation System — Environment Variables
#
# SETUP:
#   cp .env.example .env
#   nano .env        ← fill in real values
#
# ENVIRONMENTS:
#   Local XAMPP  → change DB_HOST=localhost, REACT_APP_API_URL=http://localhost/...
#   Docker       → DB_HOST=mysql, REACT_APP_API_URL=/api  (defaults below)
#   VPS/Prod     → set APP_URL to your real domain, strong passwords
#
# SECURITY:
#   .env is in .gitignore — NEVER commit it to git.
#   Only .env.example is committed (no real secrets).
# ============================================================


# ── Application ────────────────────────────────────────────
APP_NAME=Barcode Portal
# Public URL of your server (no trailing slash).
# Docker local : http://localhost
# VPS/Domain   : https://yourdomain.com
APP_URL=http://localhost

# true = show PHP errors in response (local dev only)
# false = hide errors (production)
DEBUG_MODE=false


# ── MySQL Container ────────────────────────────────────────
# These are used by the MySQL Docker container on first start.
MYSQL_ROOT_PASSWORD=changeme_root_password
MYSQL_DATABASE=barcode_portal
MYSQL_USER=barcode_user
MYSQL_PASSWORD=changeme_db_password


# ── Backend PHP Database Connection ───────────────────────
# Docker  : DB_HOST=mysql  (service name inside Docker network)
# XAMPP   : DB_HOST=localhost
DB_HOST=mysql
DB_PORT=3306
DB_NAME=barcode_portal
DB_USER=barcode_user
DB_PASSWORD=changeme_db_password

# File storage paths (inside backend container / XAMPP htdocs)
# Docker  : /var/www/html/uploads  /var/www/html/logs
# XAMPP   : leave blank → PHP uses its own defaults
UPLOAD_PATH=/var/www/html/uploads
LOG_PATH=/var/www/html/logs


# ── React Frontend ─────────────────────────────────────────
# Baked into the React bundle at build time (not runtime).
#
# Docker production → /api          (nginx proxies /api → backend)
# Local XAMPP dev  → http://localhost/mini-automation/backend/api
REACT_APP_API_URL=/api
REACT_APP_APP_NAME=Barcode Portal


# ── Python Bot ─────────────────────────────────────────────
# Full URL of the PHP API the bot calls (Python requests library).
# Docker  : http://nginx/api        (goes through nginx → backend)
# XAMPP   : http://localhost/mini-automation/backend/api
API_BASE_URL=http://nginx/api

# Seconds between job polls (lower = faster, higher = less CPU)
BOT_POLL_INTERVAL=5

# true = headless browser (no GUI) — required in Docker/VPS
# false = show browser window (local dev / debugging only)
HEADLESS=true

# Milliseconds between Playwright actions.
# 0 = as fast as possible (production)
# 300-500 = watchable speed (debugging)
SLOW_MO=0

# true = save a screenshot after EVERY field fill (verbose debugging)
# false = only save screenshots on errors
DEBUG_SCREENSHOTS=false

# ── Nginx Ports (optional, default 80/443) ─────────────────
# Change if port 80 is already in use on your host.
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443


# ── File Paths ──────────────────────────────────────────────
# NOTE: In Docker, these are OVERRIDDEN by docker-compose.yml
# environment blocks (container paths are fixed by volume mounts).
# These values are used when running outside Docker (XAMPP/VPS bare metal).
#
# Leave blank to use code defaults (relative paths inside bot/ directory).
DOWNLOAD_PATH=/app/downloads
SCREENSHOT_PATH=/app/screenshots
# LOG_PATH is shared — backend uses /var/www/html/logs, bot uses /app/logs
# In Docker, both are overridden per-container. Leave blank for local dev.
# LOG_PATH=
