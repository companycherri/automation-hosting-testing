# ============================================================
# frontend/.dockerignore
#
# frontend build context is ./frontend (not project root).
# Docker reads THIS file, NOT the root .dockerignore.
# Without this file, node_modules/ (if present) would be
# sent to Docker — potentially hundreds of MB.
# ============================================================

# ── Installed dependencies — reinstalled inside Docker ─────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json.bak

# ── Build output — regenerated by npm run build ────────────
build/
dist/

# ── Environment files ──────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Test cache ─────────────────────────────────────────────
coverage/
.jest-cache/

# ── Git ────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── IDE / OS ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
Desktop.ini

# ── Docs ───────────────────────────────────────────────────
*.md
