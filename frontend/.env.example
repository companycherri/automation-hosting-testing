# ============================================================
# React Frontend — Local Development Environment
#
# For local XAMPP development:
#   cp frontend/.env.example frontend/.env.local
#
# For Docker production, these are passed as build args
# in docker-compose.yml — you don't need a file here.
#
# React only reads REACT_APP_* prefixed variables.
# These are baked into the JS bundle at build time (not runtime).
# ============================================================

# API base URL used by all API calls in src/api/api.js
# Local XAMPP : http://localhost/mini-automation/backend/api
# Docker      : /api  (set in docker-compose build args)
REACT_APP_API_URL=http://localhost/mini-automation/backend/api

# App display name (shown in browser tab, headers, etc.)
REACT_APP_APP_NAME=Barcode Portal
